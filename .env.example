# Application
NEXT_PUBLIC_APP_NAME="Szállásfoglalási rendszer"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://app:app_password@localhost:5432/foglalo01?schema=public"

# Prisma
PRISMA_SCHEMA_PATH="./prisma/schema.prisma"

# Security
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_ADMIN_EMAIL="admin@example.com"
ADMIN_SESSION_COOKIE_NAME="admin_session"
ADMIN_SESSION_TTL_HOURS="12"
ADMIN_2FA_CODE_TTL_MINUTES="10"
ADMIN_2FA_MAX_ATTEMPTS="5"
ADMIN_2FA_RESEND_COOLDOWN_SECONDS="60"
ADMIN_PASSWORD_MAX_ATTEMPTS="5"
ADMIN_LOCKOUT_MINUTES="15"
AUTH_DUMMY_PASSWORD_HASH=""

# Email outbox (development provider only; no real delivery)
EMAIL_PROVIDER="console"
EMAIL_FROM_NAME="Szállásfoglalás"
EMAIL_FROM_ADDRESS="foglalas@example.com"
EMAIL_REPLY_TO=""
BOOKING_NOTIFICATION_EMAIL="admin@example.com"
EMAIL_MAX_ATTEMPTS="5"
EMAIL_DEBUG_CONTENT="false"
