generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  QUOTED
  AWAITING_APPROVAL
  CONFIRMED
  REJECTED
  CANCELLED
  EXPIRED
  ICAL_IMPORTED
}

enum EmailType {
  BOOKING_REQUEST_GUEST
  BOOKING_REQUEST_ADMIN
  BOOKING_CONFIRMED_GUEST
  BOOKING_REJECTED_GUEST
}

enum EmailStatus {
  PENDING
  PROCESSING
  SENT
  RETRY
  FAILED
  CANCELLED
}

model AccommodationUnit {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookings       Booking[]
  calendarBlocks CalendarBlock[]
  pricingRules   PricingRule[]
}

model Booking {
  id                String                     @id @default(cuid())
  publicReference   String                     @unique
  unitId            String
  checkInDate       DateTime                   @db.Date
  checkOutDate      DateTime                   @db.Date
  status            BookingStatus              @default(PENDING)
  guestName         String
  guestEmail        String
  guestPhone        String?
  adultCount        Int
  childCount        Int                        @default(0)
  notes             String?
  source            String                     @default("DIRECT")
  quotedTotal       Decimal?                   @db.Decimal(12, 2)
  currency          String                     @default("HUF") @db.VarChar(3)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  confirmedAt       DateTime?
  cancelledAt       DateTime?
  privacyAcceptedAt DateTime?
  accommodation     AccommodationUnit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  guests            BookingGuest[]
  children          BookingChild[]
  statusHistory     BookingStatusHistory[]
  priceSnapshot     BookingPriceSnapshot?
  idempotencyRecord BookingRequestIdempotency?
  emailOutbox       EmailOutbox[]

  @@index([unitId, checkInDate, checkOutDate])
  @@index([unitId, status, checkInDate, checkOutDate])
}

model BookingGuest {
  id        String   @id @default(cuid())
  bookingId String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model BookingChild {
  id        String   @id @default(cuid())
  bookingId String
  age       Int
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model BookingStatusHistory {
  id         String         @id @default(cuid())
  bookingId  String
  fromStatus BookingStatus?
  toStatus   BookingStatus
  reason     String?
  createdAt  DateTime       @default(now())
  booking    Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

model CalendarBlock {
  id            String            @id @default(cuid())
  unitId        String
  startDate     DateTime          @db.Date
  endDate       DateTime          @db.Date
  reason        String?
  source        String            @default("MANUAL")
  externalUid   String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accommodation AccommodationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, startDate, endDate])
}

model PricingRule {
  id             String            @id @default(cuid())
  unitId         String
  name           String
  startDate      DateTime?         @db.Date
  endDate        DateTime?         @db.Date
  nightlyRate    Decimal           @db.Decimal(12, 2)
  currency       String            @default("HUF") @db.VarChar(3)
  minimumNights  Int               @default(1)
  maximumNights  Int?
  baseGuestCount Int               @default(2)
  extraAdultFee  Decimal           @default(0) @db.Decimal(12, 2)
  childRates     Json
  cleaningFee    Decimal           @default(0) @db.Decimal(12, 2)
  version        Int               @default(1)
  priority       Int               @default(0)
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  accommodation  AccommodationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, active, startDate, endDate])
}

model BookingPriceSnapshot {
  id                    String   @id @default(cuid())
  bookingId             String   @unique
  numberOfNights        Int
  subtotal              Decimal  @db.Decimal(12, 2)
  nightlyRate           Decimal  @db.Decimal(12, 2)
  accommodationSubtotal Decimal  @db.Decimal(12, 2)
  extraAdultFee         Decimal  @db.Decimal(12, 2)
  childrenFee           Decimal  @db.Decimal(12, 2)
  cleaningFee           Decimal  @db.Decimal(12, 2)
  tourismTax            Decimal  @default(0) @db.Decimal(12, 2)
  discount              Decimal  @default(0) @db.Decimal(12, 2)
  total                 Decimal  @db.Decimal(12, 2)
  currency              String   @db.VarChar(3)
  pricingRuleId         String
  pricingRuleVersion    Int
  breakdown             Json
  createdAt             DateTime @default(now())
  booking               Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model BookingRequestIdempotency {
  id          String   @id @default(cuid())
  key         String   @unique
  requestHash String
  response    Json
  bookingId   String   @unique
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model EmailOutbox {
  id                String      @id @default(cuid())
  type              EmailType
  status            EmailStatus @default(PENDING)
  recipient         String
  subject           String
  textBody          String
  htmlBody          String
  bookingId         String?
  attemptCount      Int         @default(0)
  maxAttempts       Int         @default(5)
  nextAttemptAt     DateTime    @default(now())
  sentAt            DateTime?
  failedAt          DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?
  providerMessageId String?
  deduplicationKey  String      @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  booking           Booking?    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([bookingId])
}
